# Database
DATABASE_URL=postgresql+psycopg2://diaintel:diaintel_pass@postgres:5432/diaintel
POSTGRES_USER=diaintel
POSTGRES_PASSWORD=diaintel_pass
POSTGRES_DB=diaintel

# Redis
REDIS_URL=redis://redis:6379/0

# Models
MODEL_CACHE_DIR=/models
BIOBERT_MODEL=dmis-lab/biobert-base-cased-v1.2
DISTILBERT_MODEL=distilbert-base-uncased
ROBERTA_MODEL=cardiffnlp/twitter-roberta-base-sentiment
BART_MODEL=facebook/bart-large-mnli

# Data
PUSHSHIFT_DATA_DIR=/app/data/raw

# App
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Cache
REDIS_CACHE_TTL=300

# Processing
BATCH_SIZE=1000
MIN_POST_LENGTH=20
